<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:amasty:module:Amasty_ExportCore:etc/am_export.xsd">
    <entity code="url_rewrite_product">
        <name>Product Url Rewrite</name>
        <group>URL Rewrites</group>
        <collectionFactory class="Amasty\ExportCore\Export\Config\CustomEntity\CollectionFactory">
            <arguments>
                <argument name="tableName" xsi:type="string">url_rewrite</argument>
                <argument name="idField" xsi:type="string">url_rewrite_id</argument>
            </arguments>
        </collectionFactory>
        <collectionModifier class="Amasty\UrlRewriteExportEntity\Export\EntityType\CollectionModifier">
            <arguments>
                <argument name="entity_type" xsi:type="string">product</argument>
            </arguments>
        </collectionModifier>
        <fieldsConfig>
            <fieldsClass class="Amasty\ExportCore\Export\FieldsClass\Describe"/>
            <fields>
                <field name="entity_id">
                    <actions>
                        <custom preselected="true" class="Amasty\UrlRewriteExportEntity\Export\DataHandling\FieldModifier\Product\ProductId2Sku"/>
                    </actions>
                    <map>product_sku</map>
                </field>
                <field name="entity_type"/>
                <field name="request_path"/>
                <field name="target_path"/>
                <field name="redirect_type">
                    <filter>
                        <type>select</type>
                        <options>
                            <class>Magento\UrlRewrite\Model\OptionProvider</class>
                        </options>
                    </filter>
                </field>
                <field name="store_id">
                    <actions>
                        <storeId2StoreCode/>
                    </actions>
                    <filter>
                        <type>select</type>
                        <options>
                            <class>Magento\Cms\Ui\Component\Listing\Column\Cms\Options</class>
                        </options>
                    </filter>
                </field>
                <field name="is_autogenerated">
                    <filter>
                        <type>toggle</type>
                    </filter>
                </field>
            </fields>
            <virtualFields>
                <virtualField name="categories">
                    <generator class="Amasty\UrlRewriteExportEntity\Export\DataHandling\FieldGenerator\Categories"/>
                </virtualField>
            </virtualFields>
        </fieldsConfig>
    </entity>
</config>
