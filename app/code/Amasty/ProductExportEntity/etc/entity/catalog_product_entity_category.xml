<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:amasty:module:Amasty_ExportCore:etc/am_export.xsd">
    <entity code="catalog_product_entity_category">
        <name>Product Category</name>
        <group>Product</group>
        <collectionFactory class="Amasty\ProductExportEntity\Model\ResourceModel\Category\CollectionFactory"/>
        <collectionModifier class="Amasty\ProductExportEntity\Export\Category\CategoryCollectionModifier"/>
        <fieldsConfig>
            <fieldsClass class="Amasty\ExportCore\Export\FieldsClass\Describe"/>
            <fields>
                <field name="attribute_set_id">
                    <filter>
                        <type>select</type>
                        <options>
                            <class>Magento\Catalog\Model\Product\AttributeSet\Options</class>
                        </options>
                    </filter>
                </field>
                <field name="product_id"/>
                <field name="product_sku"/>
            </fields>
        </fieldsConfig>
    </entity>
    <relation code="catalog_product_entity_category">
        <parent_entity>catalog_product_entity</parent_entity>
        <child_entity>catalog_product_entity_category</child_entity>
        <sub_entity_field_name>catalog_product_category</sub_entity_field_name>
        <type>one_to_many</type>
        <arguments>
            <argument name="parent_field_name" xsi:type="string">entity_id</argument>
            <argument name="child_field_name" xsi:type="string">product_id</argument>
        </arguments>
    </relation>
    <relation code="category_catalog_product_entity">
        <parent_entity>catalog_product_entity_category</parent_entity>
        <child_entity>catalog_product_entity</child_entity>
        <sub_entity_field_name>catalog_product_entity</sub_entity_field_name>
        <type>one_to_many</type>
        <arguments>
            <argument name="parent_field_name" xsi:type="string">product_id</argument>
            <argument name="child_field_name" xsi:type="string">entity_id</argument>
        </arguments>
    </relation>
</config>
