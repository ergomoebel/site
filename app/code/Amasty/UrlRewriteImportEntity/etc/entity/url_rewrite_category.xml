<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:amasty:module:Amasty_ImportCore:etc/am_import.xsd">
    <entity code="url_rewrite_category">
        <name>Category Url Rewrite</name>
        <group>URL Rewrites</group>
        <description>URL Rewrite Category Import Entity</description>
        <fieldsConfig>
            <fieldsClass class="Amasty\ImportCore\Import\FieldsClass\Describe">
                <arguments>
                    <argument name="tableName" xsi:type="string">url_rewrite</argument>
                </arguments>
            </fieldsClass>
            <rowValidation class="Amasty\UrlRewriteImportEntity\Import\Validation\RowValidator\UrlRewrite">
                <excludeBehaviors>
                    <deleteDirect/>
                    <updateDirect/>
                    <addUpdateDirect/>
                </excludeBehaviors>
            </rowValidation>
            <fields rowActionClass="Amasty\UrlRewriteImportEntity\Import\DataHandling\RowModifier\UrlRewrite\Category">
                <field name="url_rewrite_id">
                    <actions>
                        <trim apply="beforeValidate"/>
                    </actions>
                    <validation>
                        <nonNegative/>
                        <notEmpty>
                            <excludeBehaviors>
                                <addDirect/>
                            </excludeBehaviors>
                        </notEmpty>
                    </validation>
                </field>
                <field name="entity_type">
                    <remove>true</remove>
                </field>
                <field name="entity_id">
                    <remove>true</remove>
                </field>
                <field name="categories">
                    <actions>
                        <trim/>
                        <custom class="Amasty\UrlRewriteImportEntity\Import\DataHandling\FieldModifier\CatNamesPath2CatId"
                                apply="beforeValidate"/>
                    </actions>
                    <validation>
                        <notEmpty error="Field 'categories' is empty or specified category doesn't exist"/>
                        <integer/>
                        <nonNegative/>
                        <tableRowExists tableName="catalog_category_entity"
                                        idFieldName="entity_id"
                                        error="Category entity with specified 'name' doesn't exist">
                            <excludeBehaviors>
                                <deleteDirect/>
                            </excludeBehaviors>
                        </tableRowExists>
                    </validation>
                    <required/>
                </field>
                <field name="request_path">
                    <validation>
                        <notEmpty/>
                    </validation>
                    <required/>
                </field>
                <field name="target_path">
                    <validation>
                        <notEmpty/>
                    </validation>
                    <required/>
                </field>
                <field name="redirect_type">
                    <validation>
                        <notEmpty isZeroValueAllowed="true"/>
                    </validation>
                    <required/>
                </field>
                <field name="store_id">
                    <validation>
                        <storeExists/>
                    </validation>
                    <required/>
                </field>
                <field name="is_autogenerated">
                    <validation>
                        <boolean/>
                    </validation>
                    <required/>
                </field>
            </fields>
            <sampleData>
                <row>
                    <field name='url_rewrite_id'>1</field>
                    <field name='categories'>Default Category/Gear</field>
                    <field name='request_path'>gear.html</field>
                    <field name='target_path'>catalog/category/view/id/1</field>
                    <field name='redirect_type'>0</field>
                    <field name='store_id'>1</field>
                    <field name='description'/>
                    <field name='is_autogenerated'>1</field>
                    <field name='metadata'/>
                </row>
            </sampleData>
        </fieldsConfig>
        <behaviors>
            <addUpdateDirect name="Add/Update">
                <tableName>url_rewrite</tableName>
            </addUpdateDirect>
            <addDirect name="Only add">
                <tableName>url_rewrite</tableName>
            </addDirect>
            <updateDirect name="Only update">
                <tableName>url_rewrite</tableName>
            </updateDirect>
            <deleteDirect name="Delete">
                <tableName>url_rewrite</tableName>
            </deleteDirect>
        </behaviors>
    </entity>
</config>
